{
	"info": {
		"_postman_id": "notes-app-mongodb-api",
		"name": "Notes App with MongoDB API",
		"description": "REST API for the Notes app: auth (register, login, refresh) and notes CRUD.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"variable": [
		{
			"key": "baseUrl",
			"value": "http://localhost:8080"
		},
		{
			"key": "accessToken",
			"value": ""
		},
		{
			"key": "refreshToken",
			"value": ""
		}
	],
	"item": [
		{
			"name": "Auth",
			"item": [
				{
					"name": "Register",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"email\": \"user@example.com\",\n  \"password\": \"yourSecurePassword\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/auth/register",
							"host": ["{{baseUrl}}"],
							"path": ["api", "auth", "register"]
						},
						"description": "Register a new user. Returns the created user (id, email)."
					}
				},
				{
					"name": "Login",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 200) {",
									"    const json = pm.response.json();",
									"    if (json.accessToken) pm.collectionVariables.set('accessToken', json.accessToken);",
									"    if (json.refreshToken) pm.collectionVariables.set('refreshToken', json.refreshToken);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"email\": \"user@example.com\",\n  \"password\": \"yourSecurePassword\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/auth/login",
							"host": ["{{baseUrl}}"],
							"path": ["api", "auth", "login"]
						},
						"description": "Login with email and password. Returns accessToken and refreshToken. Saves them to collection variables for use in Notes requests."
					}
				},
				{
					"name": "Refresh",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 200) {",
									"    const json = pm.response.json();",
									"    if (json.accessToken) pm.collectionVariables.set('accessToken', json.accessToken);",
									"    if (json.refreshToken) pm.collectionVariables.set('refreshToken', json.refreshToken);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/auth/refresh",
							"host": ["{{baseUrl}}"],
							"path": ["api", "auth", "refresh"]
						},
						"description": "Exchange a valid refresh token for a new access token and refresh token. Uses the refreshToken from collection variables (set after Login)."
					}
				}
			]
		},
		{
			"name": "Notes",
			"item": [
				{
					"name": "Create Note",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "Authorization",
								"value": "Bearer {{accessToken}}"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"id\": null,\n  \"title\": \"My first note\",\n  \"content\": \"This is the note content.\",\n  \"color\": 4294198070\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/notes",
							"host": ["{{baseUrl}}"],
							"path": ["api", "notes"]
						},
						"description": "Create a new note. Requires Authorization: Bearer <accessToken>. Omit id or set to null for create. color is a Long (e.g. ARGB integer)."
					}
				},
				{
					"name": "Update Note",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "Authorization",
								"value": "Bearer {{accessToken}}"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"id\": \"PUT_NOTE_ID_HERE\",\n  \"title\": \"Updated title\",\n  \"content\": \"Updated content.\",\n  \"color\": 4294198070\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/notes",
							"host": ["{{baseUrl}}"],
							"path": ["api", "notes"]
						},
						"description": "Update an existing note. Set id to the note's id (from Create or Get All Notes). Must be the note owner."
					}
				},
				{
					"name": "Get All Notes",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{accessToken}}"
							}
						],
						"url": {
							"raw": "{{baseUrl}}/api/notes",
							"host": ["{{baseUrl}}"],
							"path": ["api", "notes"]
						},
						"description": "List all notes for the authenticated user. Returns array of { id, title, content, color, createdAt }."
					}
				},
				{
					"name": "Delete Note",
					"request": {
						"method": "DELETE",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{accessToken}}"
							}
						],
						"url": {
							"raw": "{{baseUrl}}/api/notes/:id",
							"host": ["{{baseUrl}}"],
							"path": ["api", "notes", ":id"],
							"variable": [
								{
									"key": "id",
									"value": "PUT_NOTE_ID_HERE"
								}
							]
						},
						"description": "Delete a note by id. Only the note owner can delete. Replace :id with the note's id."
					}
				}
			]
		}
	]
}
